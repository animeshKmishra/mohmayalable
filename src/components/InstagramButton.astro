---
/**
 * InstagramButton Component
 * Opens Instagram DM with pre-filled message copied to clipboard
 *
 * Features:
 * - Copies product inquiry message to clipboard
 * - Opens Instagram app on mobile, web on desktop
 * - Shows toast notification for user feedback
 * - Fallback handling for various scenarios
 */

interface Props {
  productId: string;
  productName: string;
  productPrice: string;
  variant?: 'primary' | 'outline' | 'instagram';
  size?: 'small' | 'medium' | 'large';
  fullWidth?: boolean;
  class?: string;
}

const {
  productId,
  productName,
  productPrice,
  variant = 'instagram',
  size = 'medium',
  fullWidth = false,
  class: className = '',
} = Astro.props;

const instagramHandle = 'mohmayalabel';
---

<button
  class:list={[
    'instagram-btn',
    `instagram-btn--${variant}`,
    `instagram-btn--${size}`,
    { 'instagram-btn--full': fullWidth },
    className
  ]}
  data-product-id={productId}
  data-product-name={productName}
  data-product-price={productPrice}
  data-instagram-handle={instagramHandle}
  aria-label={`Inquire about ${productName} on Instagram`}
>
  <svg class="instagram-btn__icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
  </svg>
  <span class="instagram-btn__text">Inquire on Instagram</span>
</button>

<style>
  /* Instagram Button Base */
  .instagram-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-family: var(--font-body);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-lg);
    border: none;
    cursor: pointer;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .instagram-btn:focus-visible {
    outline: 3px solid var(--color-gold);
    outline-offset: 2px;
  }

  /* Sizes */
  .instagram-btn--small {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }

  .instagram-btn--small .instagram-btn__icon {
    width: 18px;
    height: 18px;
  }

  .instagram-btn--medium {
    padding: 0.875rem 1.5rem;
    font-size: 1rem;
  }

  .instagram-btn--large {
    padding: 1.25rem 2rem;
    font-size: 1.125rem;
  }

  .instagram-btn--full {
    width: 100%;
  }

  /* Variants */
  .instagram-btn--primary {
    background: linear-gradient(135deg, var(--color-primary-purple) 0%, var(--color-primary-royal-blue) 100%);
    color: white;
    box-shadow: var(--shadow-md);
  }

  .instagram-btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(74, 20, 140, 0.3);
  }

  .instagram-btn--outline {
    background-color: transparent;
    border: 2px solid var(--color-primary-purple);
    color: var(--color-primary-purple);
  }

  .instagram-btn--outline:hover {
    background-color: var(--color-primary-purple);
    color: white;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .instagram-btn--instagram {
    background: linear-gradient(135deg, #833AB4 0%, #FD1D1D 50%, #F77737 100%);
    color: white;
    box-shadow: var(--shadow-md);
  }

  .instagram-btn--instagram::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.5s;
  }

  .instagram-btn--instagram:hover::before {
    left: 100%;
  }

  .instagram-btn--instagram:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(131, 58, 180, 0.4);
  }

  /* Icon */
  .instagram-btn__icon {
    flex-shrink: 0;
    transition: transform var(--transition-base);
  }

  .instagram-btn:hover .instagram-btn__icon {
    transform: scale(1.1) rotate(5deg);
  }

  /* Text */
  .instagram-btn__text {
    position: relative;
    z-index: 1;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .instagram-btn--large {
      padding: 1rem 1.5rem;
      font-size: 1rem;
    }
  }
</style>

<script>
  // Instagram Button Click Handler
  function handleInstagramClick(event: Event) {
    const button = event.currentTarget as HTMLButtonElement;
    const productId = button.dataset.productId || '';
    const productName = button.dataset.productName || '';
    const productPrice = button.dataset.productPrice || '';
    const instagramHandle = button.dataset.instagramHandle || 'mohmayalabel';

    // Generate pre-filled message
    const message = `Hi! I'm interested in ${productName} (${productId}) - ${productPrice}. Is this available?`;

    // Instagram URLs
    const instagramDmUrl = `https://ig.me/m/${instagramHandle}`;
    const instagramAppUrl = `instagram://user?username=${instagramHandle}`;

    // Detect device type
    const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);

    // Copy to clipboard
    copyToClipboard(message)
      .then(() => {
        // Show success toast
        window.showToast({
          type: 'success',
          title: 'Message Copied!',
          message: 'Opening Instagram... Paste the message to inquire.'
        });

        // Open Instagram
        if (isMobile) {
          // Try to open Instagram app on mobile
          window.location.href = instagramAppUrl;

          // Fallback to web after 1.5 seconds if app doesn't open
          setTimeout(() => {
            window.open(instagramDmUrl, '_blank');
          }, 1500);
        } else {
          // Open Instagram web on desktop
          window.open(instagramDmUrl, '_blank');
        }
      })
      .catch((error) => {
        console.error('Clipboard error:', error);

        // Show fallback toast
        window.showToast({
          type: 'info',
          title: 'Opening Instagram',
          message: `Please send: "${message.substring(0, 50)}..."`
        });

        // Still open Instagram
        window.open(instagramDmUrl, '_blank');
      });
  }

  // Clipboard API with fallback
  async function copyToClipboard(text: string): Promise<void> {
    // Try modern Clipboard API
    if (navigator.clipboard && window.isSecureContext) {
      try {
        await navigator.clipboard.writeText(text);
        return;
      } catch (err) {
        console.warn('Clipboard API failed, trying fallback:', err);
      }
    }

    // Fallback for older browsers
    return copyToClipboardFallback(text);
  }

  function copyToClipboardFallback(text: string): Promise<void> {
    return new Promise((resolve, reject) => {
      const textArea = document.createElement('textarea');
      textArea.value = text;
      textArea.style.position = 'fixed';
      textArea.style.left = '-999999px';
      textArea.style.top = '-999999px';
      document.body.appendChild(textArea);

      textArea.focus();
      textArea.select();

      try {
        const successful = document.execCommand('copy');
        textArea.remove();

        if (successful) {
          resolve();
        } else {
          reject(new Error('Copy command failed'));
        }
      } catch (err) {
        textArea.remove();
        reject(err);
      }
    });
  }

  // Attach event listeners to all Instagram buttons
  document.addEventListener('DOMContentLoaded', () => {
    const instagramButtons = document.querySelectorAll('.instagram-btn');

    instagramButtons.forEach((button) => {
      button.addEventListener('click', handleInstagramClick);
    });
  });

  // Re-attach listeners for dynamically added buttons (if any)
  if (typeof window !== 'undefined') {
    (window as any).attachInstagramListeners = () => {
      const instagramButtons = document.querySelectorAll('.instagram-btn');
      instagramButtons.forEach((button) => {
        button.removeEventListener('click', handleInstagramClick);
        button.addEventListener('click', handleInstagramClick);
      });
    };
  }
</script>
