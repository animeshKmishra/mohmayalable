---
// Hero section - Main landing area with brand showcase
---

<section class="hero">
  <div class="hero__background">
    <div class="hero__pattern"></div>
  </div>

  <div class="container">
    <div class="hero__content">
      <!-- Logo -->
      <div class="hero__logo" data-aos="fade-up" data-aos-duration="1000">
        <span class="hero__logo-frame" aria-hidden="true">
          <img
            src="/images/lable.png"
            alt="MohMaya Logo"
            class="hero__logo-img"
            width="280"
            height="280"
            loading="eager"
            decoding="async"
          />
        </span>
      </div>

      <!-- Brand Title -->
      <h1 class="hero__title" data-aos="fade-up" data-aos-delay="200" data-aos-duration="1000">
        MohMaya Lable
      </h1>

      <!-- Tagline -->
      <p class="hero__tagline" data-aos="fade-up" data-aos-delay="400" data-aos-duration="1000">
        Threads of Elegance
      </p>

      <!-- Description -->
      <p class="hero__description" data-aos="fade-up" data-aos-delay="600" data-aos-duration="1000">
        Discover exquisite handcrafted sarees that blend timeless tradition with contemporary grace.
        Each piece tells a story of artistry, heritage, and unparalleled elegance.
      </p>

      <!-- CTA Button -->
      <div class="hero__cta" data-aos="fade-up" data-aos-delay="800" data-aos-duration="1000">
        <a href="#products" class="btn btn--primary">
          <span>Explore Collection</span>
          <svg class="btn__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <!-- Scroll Indicator -->
      <div class="scroll-indicator" data-aos="fade-up" data-aos-delay="1000">
        <span class="scroll-text">Scroll to Explore</span>
        <svg class="scroll-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <polyline points="19 12 12 19 5 12"></polyline>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 0 4rem;
    overflow: hidden;
    background: linear-gradient(
      180deg,
      #FFF8F0 0%,
      #F5EFE7 50%,
      #E8DCC7 100%
    );
  }

  /* Background Pattern */
  .hero__background {
    position: absolute;
    inset: 0;
    opacity: 0.3;
    z-index: 0;
  }

  .hero__pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(184, 134, 11, 0.1) 1px, transparent 1px),
      radial-gradient(circle at 60% 70%, rgba(93, 64, 55, 0.08) 1px, transparent 1px),
      radial-gradient(circle at 80% 20%, rgba(184, 134, 11, 0.1) 1px, transparent 1px),
      repeating-linear-gradient(90deg, rgba(93, 64, 55, 0.02) 0px, transparent 1px, transparent 60px);
    background-size: 300px 300px, 200px 200px, 250px 250px, 60px 60px;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  /* Logo */
  .hero__logo {
    margin-bottom: 2.5rem;
    display: flex;
    justify-content: center;
  }

  /* Logo Frame - circular background with padding */
  .hero__logo-frame {
    display: inline-block;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.8);
    filter: drop-shadow(0 8px 24px rgba(62, 39, 35, 0.2));
    padding: 2.7rem;
    transition: transform var(--transition-base);
  }

  .hero__logo-frame:hover {
    transform: scale(1.05);
  }

  /* Logo Image - clean and scalable, fills 70% of circle */
  .hero__logo-img {
    display: block;
    width: 200px;
    height: 200px;
    object-fit: contain;
    border-radius: 50%;
  }

  /* Responsive sizing - maintains 70% fill ratio */
  @media (min-width: 640px) {
    .hero__logo-img {
      width: 240px;
      height: 240px;
    }

    .hero__logo-frame {
      padding: 3.2rem;
    }
  }

  @media (min-width: 1024px) {
    .hero__logo-img {
      width: 280px;
      height: 280px;
    }

    .hero__logo-frame {
      padding: 3.8rem;
    }
  }

  /* Title */
  .hero__title {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 700;
    color: var(--color-brown-dark);
    margin: 0 0 1rem;
    letter-spacing: 2px;
  }

  @media (max-width: 768px) {
    .hero__title {
      font-size: 2.75rem;
    }
  }

  /* Tagline */
  .hero__tagline {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--color-brown-medium);
    margin: 0 0 2.5rem;
    letter-spacing: 1px;
  }

  @media (max-width: 768px) {
    .hero__tagline {
      font-size: 1.375rem;
    }
  }

  /* Description */
  .hero__description {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-brown-medium);
    max-width: 650px;
    margin: 0 auto 3rem;
    padding: 0 1.5rem;
  }

  @media (max-width: 768px) {
    .hero__description {
      font-size: 1rem;
      padding: 0 1rem;
    }
  }

  /* CTA Button */
  .hero__cta {
    margin-bottom: 4rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
    cursor: pointer;
    letter-spacing: 0.5px;
  }

  .btn--primary {
    background: var(--color-gold);
    color: white;
    box-shadow: 0 4px 16px rgba(184, 134, 11, 0.25);
  }

  .btn--primary:hover {
    background: var(--color-gold-light);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(184, 134, 11, 0.35);
  }

  .btn--primary:active {
    transform: translateY(0);
  }

  .btn__icon {
    transition: transform var(--transition-base);
  }

  .btn--primary:hover .btn__icon {
    transform: translateX(4px);
  }

  /* Scroll Indicator */
  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-brown-medium);
  }

  .scroll-text {
    font-size: 0.813rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 500;
    color: var(--color-brown-medium);
  }

  .scroll-arrow {
    color: var(--color-brown-medium);
  }

  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .scroll-indicator {
      animation: none;
    }

    .hero__pattern {
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 6rem 0 3rem;
    }

    .btn {
      padding: 0.875rem 2rem;
      font-size: 0.938rem;
    }
  }
</style>
