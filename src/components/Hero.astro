---
// Hero section - Brand showcase with elegant animations
---

<section class="hero">
  <div class="hero__background">
    <div class="hero__pattern"></div>
  </div>

  <div class="container">
    <div class="hero__content" data-aos="fade-up" data-aos-duration="1000">
      <!-- Logo -->
      <div class="hero__logo" data-aos="zoom-in" data-aos-delay="200">
        <img src="/images/logo.png" alt="MohMaya Logo" class="hero__logo-img" />
      </div>

      <!-- Brand Name -->
      <h1 class="hero__title" data-aos="fade-up" data-aos-delay="400">
        MohMaya
      </h1>

      <!-- Tagline -->
      <p class="hero__tagline" data-aos="fade-up" data-aos-delay="600">
        Threads of Elegance
      </p>

      <!-- Description -->
      <p class="hero__description" data-aos="fade-up" data-aos-delay="800">
        Where tradition meets contemporary grace. Each saree is a masterpiece,
        handcrafted with love and adorned with timeless elegance.
      </p>

      <!-- CTA Button -->
      <div class="hero__cta" data-aos="fade-up" data-aos-delay="1000">
        <a href="#products" class="btn btn--primary">
          <span>Explore Collection</span>
          <svg class="btn__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <!-- Scroll Indicator -->
      <div class="hero__scroll" data-aos="fade-in" data-aos-delay="1200">
        <div class="scroll-indicator">
          <span class="scroll-text">Scroll to explore</span>
          <div class="scroll-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 0 4rem;
    overflow: hidden;
    background:
      radial-gradient(ellipse at top, rgba(138, 43, 226, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at bottom, rgba(255, 215, 0, 0.1) 0%, transparent 50%),
      linear-gradient(135deg, #4A148C 0%, #6A1B9A 25%, #8E24AA 50%, #AB47BC 75%, #CE93D8 100%);
  }

  /* Background Pattern */
  .hero__background {
    position: absolute;
    inset: 0;
    opacity: 0.15;
    z-index: 0;
  }

  .hero__pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(255, 215, 0, 0.4) 2px, transparent 2px),
      radial-gradient(circle at 60% 70%, rgba(255, 255, 255, 0.3) 1px, transparent 1px),
      radial-gradient(circle at 80% 20%, rgba(255, 215, 0, 0.3) 2px, transparent 2px),
      radial-gradient(circle at 40% 90%, rgba(255, 255, 255, 0.2) 1px, transparent 1px),
      repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.03) 0px, transparent 1px, transparent 40px),
      repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.03) 0px, transparent 1px, transparent 40px);
    background-size: 400px 400px, 200px 200px, 300px 300px, 250px 250px, 40px 40px, 40px 40px;
    animation: patternMove 30s linear infinite;
  }

  @keyframes patternMove {
    from {
      transform: translate(0, 0);
    }
    to {
      transform: translate(30px, 30px);
    }
  }

  /* Hero Content */
  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  /* Logo */
  .hero__logo {
    margin-bottom: 2rem;
    animation: float 3s ease-in-out infinite;
    position: relative;
  }

  .hero__logo::before,
  .hero__logo::after {
    content: '';
    position: absolute;
    width: 120%;
    height: 120%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border: 2px solid rgba(255, 215, 0, 0.3);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  .hero__logo::after {
    animation-delay: 1s;
    border-color: rgba(255, 255, 255, 0.2);
  }

  @keyframes pulse {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(-50%, -50%) scale(1.5);
      opacity: 0;
    }
  }

  .hero__logo-img {
    width: 200px;
    height: auto;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 15px 35px rgba(255, 215, 0, 0.5)) drop-shadow(0 5px 15px rgba(74, 20, 140, 0.3));
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    padding: 1rem;
    backdrop-filter: blur(10px);
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-15px) rotate(2deg);
    }
  }

  @media (min-width: 768px) {
    .hero__logo-img {
      width: 250px;
    }
  }

  /* Title */
  .hero__title {
    font-family: var(--font-heading);
    font-size: 5rem;
    font-weight: 800;
    background: linear-gradient(135deg, #FFD700 0%, #FFF 50%, #FFD700 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 1rem;
    letter-spacing: 2px;
    text-shadow: 0 5px 15px rgba(255, 215, 0, 0.5);
    position: relative;
  }

  .hero__title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 150px;
    height: 3px;
    background: linear-gradient(90deg, transparent, #FFD700, transparent);
  }

  @media (max-width: 768px) {
    .hero__title {
      font-size: 3rem;
    }
  }

  /* Tagline */
  .hero__tagline {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 300;
    font-style: italic;
    color: rgba(255, 255, 255, 0.95);
    margin: 0 0 2.5rem;
    text-shadow: 0 3px 10px rgba(0, 0, 0, 0.3);
    letter-spacing: 3px;
  }

  @media (max-width: 768px) {
    .hero__tagline {
      font-size: 1.5rem;
    }
  }

  /* Description */
  .hero__description {
    font-size: 1.25rem;
    line-height: 1.9;
    color: rgba(255, 255, 255, 0.9);
    max-width: 650px;
    margin: 0 auto 3rem;
    padding: 0 1rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(5px);
    background: rgba(255, 255, 255, 0.05);
    padding: 1.5rem 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 215, 0, 0.2);
  }

  @media (max-width: 768px) {
    .hero__description {
      font-size: 1.125rem;
    }
  }

  /* CTA Button */
  .hero__cta {
    margin-bottom: 4rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    cursor: pointer;
    box-shadow: var(--shadow-md);
  }

  .btn--primary {
    background: linear-gradient(135deg, #FFD700 0%, #FDB931 50%, #FFD700 100%);
    color: var(--color-primary-purple);
    position: relative;
    overflow: hidden;
    font-weight: 700;
    letter-spacing: 1px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    text-transform: uppercase;
  }

  .btn--primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.5), transparent);
    transition: left 0.6s;
  }

  .btn--primary::after {
    content: '';
    position: absolute;
    inset: -2px;
    background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    border-radius: var(--radius-lg);
    animation: shimmer 3s linear infinite;
  }

  @keyframes shimmer {
    0% {
      transform: translateX(-100%) rotate(45deg);
    }
    100% {
      transform: translateX(100%) rotate(45deg);
    }
  }

  .btn--primary:hover::before {
    left: 100%;
  }

  .btn--primary:hover {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 20px 40px rgba(255, 215, 0, 0.5), 0 10px 20px rgba(74, 20, 140, 0.3);
  }

  .btn--primary:active {
    transform: translateY(-2px) scale(1.02);
  }

  .btn__icon {
    transition: transform var(--transition-base);
  }

  .btn--primary:hover .btn__icon {
    transform: translateX(5px);
  }

  /* Scroll Indicator */
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    animation: bounce 2s ease-in-out infinite;
  }

  .scroll-text {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.9);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .scroll-arrow {
    color: #FFD700;
    filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.6));
  }

  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      min-height: 90vh;
      padding: 6rem 0 3rem;
    }

    .hero__scroll {
      display: none;
    }

    .btn {
      padding: 0.875rem 2rem;
      font-size: 1rem;
    }
  }

  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .hero__logo,
    .scroll-indicator {
      animation: none;
    }

    .hero__pattern {
      animation: none;
    }
  }
</style>
