---
import type { CollectionEntry } from 'astro:content';
import InstagramButton from './InstagramButton.astro';

interface Props {
  product: CollectionEntry<'products'>;
  index?: number;
}

const { product, index = 0 } = Astro.props;
const { data, slug } = product;

// Format price with Indian number system
const formattedPrice = new Intl.NumberFormat('en-IN', {
  style: 'currency',
  currency: 'INR',
  maximumFractionDigits: 0
}).format(data.price);

// AOS delay based on index
const aosDelay = (index % 3) * 100;
---

<article
  class="product-card"
  data-aos="fade-up"
  data-aos-delay={aosDelay}
>
  <a href={`/product/${slug}`} class="product-card__link">
    <!-- Image Container -->
    <div class="product-card__image-wrapper">
      <img
        src={data.image}
        alt={data.title}
        class="product-card__image"
        loading="lazy"
        width="600"
        height="800"
      />

      <!-- Badges -->
      <div class="product-card__badges">
        {data.featured && (
          <span class="badge badge--featured">Featured</span>
        )}
        {!data.available && (
          <span class="badge badge--sold-out">Sold Out</span>
        )}
      </div>

      <!-- Hover Overlay -->
      <div class="product-card__overlay">
        <span class="product-card__view-details">View Details</span>
      </div>
    </div>

    <!-- Content -->
    <div class="product-card__content">
      <!-- Product ID Badge -->
      <span class="product-card__id">{data.productId}</span>

      <!-- Title -->
      <h3 class="product-card__title">{data.title}</h3>

      <!-- Meta Info -->
      <div class="product-card__meta">
        {data.fabric && (
          <span class="meta-tag meta-tag--fabric">{data.fabric}</span>
        )}
        {data.color && (
          <span class="meta-tag meta-tag--color">{data.color}</span>
        )}
      </div>

      <!-- Price -->
      <div class="product-card__price">
        <span class="price">{formattedPrice}</span>
      </div>

      <!-- Instagram Button -->
      <div class="product-card__cta">
        <InstagramButton
          productId={data.productId}
          productName={data.title}
          productPrice={formattedPrice}
          variant="outline"
          size="small"
          fullWidth={true}
        />
      </div>
    </div>
  </a>
</article>

<style>
  /* Product Card */
  .product-card {
    position: relative;
    background: white;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
    border: 1px solid var(--color-border);
  }

  .product-card:hover {
    box-shadow: var(--shadow-xl);
    transform: translateY(-8px);
  }

  .product-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* Image */
  .product-card__image-wrapper {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--color-primary-beige);
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .product-card:hover .product-card__image {
    transform: scale(1.05);
  }

  /* Badges */
  .product-card__badges {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: 4px;
    backdrop-filter: blur(10px);
    box-shadow: var(--shadow-sm);
  }

  .badge--featured {
    background: var(--color-gold);
    color: white;
  }

  .badge--sold-out {
    background: var(--color-brown-dark);
    color: white;
  }

  /* Overlay */
  .product-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(62, 39, 35, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    opacity: 0;
    transition: opacity var(--transition-base);
    z-index: 2;
  }

  .product-card:hover .product-card__overlay {
    opacity: 1;
  }

  .product-card__view-details {
    color: var(--color-gold);
    font-weight: 600;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 0.875rem 2rem;
    border: 2px solid var(--color-gold);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .product-card__overlay:hover .product-card__view-details {
    background: var(--color-gold);
    color: white;
  }

  /* Content */
  .product-card__content {
    padding: 1.5rem;
  }

  .product-card__id {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.75rem;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--color-gold-pale);
    border-radius: 4px;
    background: var(--color-gold-pale);
  }

  .product-card__title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-brown-dark);
    margin: 0 0 1rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Meta Tags */
  .product-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .meta-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.875rem;
    font-size: 0.813rem;
    font-weight: 500;
    border-radius: 4px;
    background-color: var(--color-primary-beige);
    color: var(--color-brown-medium);
  }

  /* Price */
  .product-card__price {
    margin-bottom: 0.5rem;
  }

  .price {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-brown-dark);
  }

  /* CTA */
  .product-card__cta {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  /* Prevent button click from triggering link */
  .product-card__cta :global(.instagram-btn) {
    pointer-events: auto;
    position: relative;
    z-index: 2;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .product-card__content {
      padding: 1.25rem;
    }

    .product-card__title {
      font-size: 1.125rem;
    }

    .price {
      font-size: 1.25rem;
    }

    .product-card__cta {
      margin-top: 1rem;
      padding-top: 1rem;
    }
  }
</style>

<script>
  // Prevent Instagram button click from triggering card link
  document.addEventListener('DOMContentLoaded', () => {
    const instagramButtons = document.querySelectorAll('.product-card__cta .instagram-btn');

    instagramButtons.forEach((button) => {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
      });
    });
  });
</script>
