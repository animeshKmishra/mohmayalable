---
// Footer component with branding and social links
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__content">
      <!-- Brand Section -->
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <img src="/images/logo.png" alt="MohMaya Logo" class="footer__logo-img" />
        </a>
        <h3 class="footer__title">MohMaya</h3>
        <p class="footer__tagline">Threads of Elegance</p>
        <p class="footer__description">
          Handcrafted sarees that blend tradition with contemporary elegance.
        </p>
      </div>

      <!-- Quick Links -->
      <div class="footer__section">
        <h4 class="footer__heading">Quick Links</h4>
        <ul class="footer__links">
          <li><a href="/" class="footer__link">Home</a></li>
          <li><a href="#products" class="footer__link">Collection</a></li>
          <li><a href="/about" class="footer__link">About Us</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div class="footer__section">
        <h4 class="footer__heading">Connect With Us</h4>
        <div class="footer__social">
          <a
            href="https://www.instagram.com/mohmayalabel"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-link"
            aria-label="Follow us on Instagram"
          >
            <svg class="social-icon" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            <span>@mohmayalabel</span>
          </a>
        </div>
        <p class="footer__contact-info">
          Reach out to us on Instagram for inquiries and orders.
        </p>
      </div>
    </div>

    <!-- Copyright -->
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {currentYear} MohMaya. All rights reserved.
      </p>
      <p class="footer__crafted">
        Handcrafted with <span class="heart">♥</span> for saree lovers
      </p>
    </div>
  </div>
</footer>

<style>
  /* Footer Styles */
  .footer {
    background: linear-gradient(135deg, var(--color-primary-purple) 0%, var(--color-primary-royal-blue) 100%);
    color: white;
    padding: 4rem 0 2rem;
    margin-top: var(--spacing-xl);
  }

  .footer__content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .footer__content {
      grid-template-columns: 2fr 1fr 1.5fr;
      gap: 4rem;
    }
  }

  /* Brand Section */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__logo {
    display: inline-block;
    width: fit-content;
    transition: transform var(--transition-base);
  }

  .footer__logo:hover {
    transform: scale(1.05);
  }

  .footer__logo-img {
    height: 60px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .footer__title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    color: white;
    margin: 0;
  }

  .footer__tagline {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-gold);
    font-style: italic;
    margin: 0;
  }

  .footer__description {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 400px;
    margin: 0.5rem 0 0 0;
  }

  /* Footer Sections */
  .footer__section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__heading {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-gold);
    margin: 0 0 0.5rem 0;
  }

  /* Links */
  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__link {
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    font-size: 1rem;
    transition: color var(--transition-fast), padding-left var(--transition-fast);
    display: inline-block;
  }

  .footer__link:hover {
    color: var(--color-gold);
    padding-left: 0.5rem;
  }

  /* Social Links */
  .footer__social {
    display: flex;
    gap: 1rem;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: white;
    text-decoration: none;
    padding: 0.75rem 1.25rem;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    font-weight: 500;
    backdrop-filter: blur(10px);
  }

  .footer__social-link:hover {
    background-color: var(--color-gold);
    color: var(--color-primary-purple);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 215, 0, 0.3);
  }

  .social-icon {
    transition: transform var(--transition-base);
  }

  .footer__social-link:hover .social-icon {
    transform: scale(1.1);
  }

  .footer__contact-info {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0.5rem 0 0 0;
  }

  /* Bottom Section */
  .footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer__copyright,
  .footer__crafted {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    margin: 0;
  }

  .heart {
    color: var(--color-gold);
    display: inline-block;
    animation: heartbeat 1.5s ease-in-out infinite;
  }

  @keyframes heartbeat {
    0%, 100% {
      transform: scale(1);
    }
    10%, 30% {
      transform: scale(1.1);
    }
    20%, 40% {
      transform: scale(1);
    }
  }

  /* Responsive adjustments */
  @media (max-width: 767px) {
    .footer {
      padding: 3rem 0 1.5rem;
    }

    .footer__content {
      gap: 2.5rem;
    }

    .footer__title {
      font-size: 1.5rem;
    }

    .footer__social-link {
      font-size: 0.9rem;
      padding: 0.625rem 1rem;
    }
  }
</style>
