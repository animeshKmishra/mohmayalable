---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import Toast from '../components/Toast.astro';
import ProductGrid from '../components/ProductGrid.astro';
---

<BaseLayout>
  <!-- Skip to main content link for accessibility -->
  <a href="#main-content" class="skip-to-content">Skip to main content</a>

  <!-- Header -->
  <Header />

  <!-- Main Content -->
  <main id="main-content">
    <!-- Hero Section -->
    <Hero />

    <!-- Products Section -->
    <section id="products" class="products-section">
      <div class="container">
        <h2 class="section-title" data-aos="fade-up">
          Our Collection
        </h2>
        <p class="section-subtitle" data-aos="fade-up" data-aos-delay="200">
          Discover our exquisite collection of handcrafted sarees. Each piece is a work of art, woven with tradition and elegance.
        </p>

        <!-- Product Grid -->
        <ProductGrid />
      </div>
    </section>
  </main>

  <!-- Footer -->
  <Footer />

  <!-- Toast Notifications -->
  <Toast />
</BaseLayout>

<style>
  /* Products Section */
  .products-section {
    padding: var(--spacing-xl) 0;
    background:
      radial-gradient(ellipse at top right, rgba(138, 43, 226, 0.05) 0%, transparent 50%),
      radial-gradient(ellipse at bottom left, rgba(255, 215, 0, 0.05) 0%, transparent 50%),
      linear-gradient(180deg, #ffffff 0%, #fafafa 50%, #f5f5f5 100%);
    position: relative;
    overflow: hidden;
  }

  .products-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      radial-gradient(circle at 20% 20%, rgba(255, 215, 0, 0.1) 1px, transparent 1px),
      radial-gradient(circle at 80% 80%, rgba(74, 20, 140, 0.1) 1px, transparent 1px);
    background-size: 50px 50px;
    opacity: 0.5;
    pointer-events: none;
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 1.25rem;
    max-width: 700px;
    margin: -2rem auto 5rem;
    line-height: 1.8;
    font-style: italic;
  }

  /* Coming Soon Card */
  .coming-soon {
    max-width: 500px;
    margin: 0 auto;
    padding: 3rem 2rem;
    text-align: center;
    background-color: var(--color-bg-cream);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .coming-soon__icon {
    margin: 0 auto 1.5rem;
    width: 64px;
    height: 64px;
    color: var(--color-primary-purple);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.7;
      transform: scale(0.95);
    }
  }

  .coming-soon__title {
    font-family: var(--font-heading);
    font-size: 2rem;
    color: var(--color-primary-purple);
    margin: 0 0 1rem;
  }

  .coming-soon__text {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .btn--outline {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 2rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border: 2px solid var(--color-primary-purple);
    color: var(--color-primary-purple);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    background-color: transparent;
  }

  .btn--outline:hover {
    background-color: var(--color-primary-purple);
    color: white;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .products-section {
      padding: var(--spacing-lg) 0;
    }

    .coming-soon {
      padding: 2rem 1.5rem;
    }

    .coming-soon__title {
      font-size: 1.75rem;
    }
  }
</style>

