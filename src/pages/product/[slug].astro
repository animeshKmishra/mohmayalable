---
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Toast from '../../components/Toast.astro';
import InstagramButton from '../../components/InstagramButton.astro';

// Generate static paths for all products
export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { data } = product;
const { Content } = await product.render();

// Format price
const formattedPrice = new Intl.NumberFormat('en-IN', {
  style: 'currency',
  currency: 'INR',
  maximumFractionDigits: 0
}).format(data.price);

// SEO
const pageTitle = data.seoTitle || `${data.title} | MohMaya`;
const pageDescription = data.seoDescription || data.description.substring(0, 160);
---

<BaseLayout title={pageTitle} description={pageDescription} image={data.image}>
  <a href="#main-content" class="skip-to-content">Skip to main content</a>
  <Header />

  <main id="main-content">
    <!-- Breadcrumb -->
    <div class="breadcrumb-wrapper">
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <ol>
            <li><a href="/">Home</a></li>
            <li><a href="/#products">Collection</a></li>
            <li aria-current="page">{data.title}</li>
          </ol>
        </nav>
      </div>
    </div>

    <!-- Product Detail -->
    <section class="product-detail">
      <div class="container">
        <div class="product-detail__grid">
          <!-- Image Gallery -->
          <div class="product-detail__images" data-aos="fade-right">
            <!-- Main Image -->
            <div class="main-image">
              <img
                id="main-image"
                src={data.image}
                alt={data.title}
                width={800}
                height={1066}
                class="main-image__img"
              />
              {!data.available && (
                <div class="sold-out-overlay">
                  <span class="sold-out-badge">Sold Out</span>
                </div>
              )}
            </div>

            <!-- Gallery Thumbnails - ALL images (main + gallery) -->
            {(() => {
              const allImages = [data.image, ...(data.gallery || [])];
              return allImages.length > 1 && (
                <div class="gallery-thumbnails">
                  {allImages.map((img, index) => (
                    <div
                      class={`thumbnail ${index === 0 ? 'thumbnail--active' : ''}`}
                      data-image={img}
                    >
                      <img
                        src={img}
                        alt={`${data.title} - View ${index + 1}`}
                        width={150}
                        height={200}
                        class="thumbnail__img"
                      />
                    </div>
                  ))}
                </div>
              );
            })()}
          </div>

          <!-- Product Info -->
          <div class="product-detail__info" data-aos="fade-left">
            <!-- Product ID -->
            <span class="product-id">{data.productId}</span>

            <!-- Title -->
            <h1 class="product-title">{data.title}</h1>

            <!-- Meta -->
            <div class="product-meta">
              {data.fabric && (
                <span class="meta-tag meta-tag--fabric">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                  </svg>
                  {data.fabric}
                </span>
              )}
              {data.color && (
                <span class="meta-tag meta-tag--color">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                  </svg>
                  {data.color}
                </span>
              )}
            </div>

            <!-- Price -->
            <div class="product-price">
              <span class="price">{formattedPrice}</span>
              {!data.available && (
                <span class="availability availability--unavailable">Currently Unavailable</span>
              )}
              {data.available && (
                <span class="availability availability--available">Available</span>
              )}
            </div>

            <!-- Description -->
            <div class="product-description prose">
              <Content />
            </div>

            <!-- CTA -->
            <div class="product-cta">
              <InstagramButton
                productId={data.productId}
                productName={data.title}
                productPrice={formattedPrice}
                variant="instagram"
                size="large"
                fullWidth={true}
              />
            </div>

            <!-- Additional Info -->
            <div class="product-info-box">
              <h3 class="info-box__title">Care Instructions</h3>
              <ul class="info-box__list">
                <li>Dry clean only for best results</li>
                <li>Store in a cool, dry place</li>
                <li>Avoid direct sunlight to prevent fading</li>
                <li>Handle with care to preserve intricate work</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <Toast />
</BaseLayout>

<style>
  /* Breadcrumb */
  .breadcrumb-wrapper {
    background-color: var(--color-bg-light);
    padding: 1rem 0;
    margin-top: 4.5rem;
  }

  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.875rem;
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
  }

  .breadcrumb li:not(:last-child)::after {
    content: '›';
    margin-left: 0.5rem;
    color: var(--color-text-muted);
  }

  .breadcrumb a {
    color: var(--color-gold);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-gold-light);
    text-decoration: underline;
  }

  .breadcrumb li[aria-current="page"] {
    color: var(--color-text-secondary);
  }

  /* Product Detail */
  .product-detail {
    padding: var(--spacing-lg) 0;
  }

  .product-detail__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .product-detail__grid {
      grid-template-columns: 1.2fr 1fr;
      gap: 4rem;
    }
  }

  /* Images */
  .main-image {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--color-bg-light);
    box-shadow: var(--shadow-lg);
  }

  .main-image__img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.3s ease;
  }

  .sold-out-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sold-out-badge {
    padding: 1rem 2rem;
    background-color: white;
    color: var(--color-text-primary);
    font-weight: 700;
    font-size: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    border-radius: var(--radius-lg);
  }

  /* Gallery */
  .gallery-thumbnails {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .thumbnail {
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: pointer;
    transition: all var(--transition-base);
    border: 3px solid transparent;
    opacity: 0.7;
  }

  .thumbnail:hover {
    transform: scale(1.05);
    opacity: 1;
  }

  .thumbnail--active {
    border-color: var(--color-gold);
    opacity: 1;
    box-shadow: 0 4px 12px rgba(184, 134, 11, 0.3);
  }

  .thumbnail__img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Product Info */
  .product-id {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 0.75rem;
  }

  .product-title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 1.5rem;
    line-height: 1.2;
  }

  @media (max-width: 768px) {
    .product-title {
      font-size: 2rem;
    }
  }

  /* Meta Tags */
  .product-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .meta-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.938rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    background-color: var(--color-bg-cream);
  }

  .meta-tag svg {
    flex-shrink: 0;
  }

  .meta-tag--fabric {
    background-color: rgba(184, 134, 11, 0.1);
    color: var(--color-gold);
  }

  .meta-tag--color {
    background-color: rgba(184, 134, 11, 0.15);
    color: var(--color-brown-dark);
  }

  /* Price */
  .product-price {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--color-border);
  }

  .price {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-brown-dark);
  }

  .availability {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .availability--available {
    background-color: rgba(16, 185, 129, 0.1);
    color: #10B981;
  }

  .availability--unavailable {
    background-color: rgba(239, 68, 68, 0.1);
    color: #EF4444;
  }

  /* Description */
  .product-description {
    margin-bottom: 2.5rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .product-description :global(p) {
    margin-bottom: 1rem;
  }

  /* CTA */
  .product-cta {
    margin-bottom: 2rem;
  }

  /* Info Box */
  .product-info-box {
    background-color: var(--color-bg-cream);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .info-box__title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 1rem;
  }

  .info-box__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .info-box__list li {
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-secondary);
    position: relative;
  }

  .info-box__list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-gold);
    font-weight: 700;
  }

  .info-box__list li:last-child {
    margin-bottom: 0;
  }
</style>

<script>
  // Gallery Image Switcher
  document.addEventListener('DOMContentLoaded', () => {
    const mainImage = document.getElementById('main-image') as HTMLImageElement;
    const thumbnails = document.querySelectorAll('.thumbnail');

    if (mainImage && thumbnails.length > 0) {
      thumbnails.forEach((thumbnail) => {
        thumbnail.addEventListener('click', () => {
          // Remove active class from all thumbnails
          thumbnails.forEach(t => t.classList.remove('thumbnail--active'));

          // Add active class to clicked thumbnail
          thumbnail.classList.add('thumbnail--active');

          // Get the image URL from data attribute
          const imageUrl = thumbnail.getAttribute('data-image');

          if (imageUrl && mainImage) {
            // Update main image with smooth transition
            mainImage.style.opacity = '0';

            setTimeout(() => {
              mainImage.src = imageUrl;
              mainImage.style.opacity = '1';
            }, 200);
          }
        });
      });
    }
  });
</script>
